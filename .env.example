# CloudCrop AI — Environment Variables Template
# Copy this file to .env and fill in the values
# ⚠️  NEVER commit .env to version control

# ── Weather API ─────────────────────────────────────────────────────────────
VITE_OPENWEATHER_API_KEY=your_openweather_api_key_here

# ── GROQ AI (server-side ONLY — never prefix with VITE_) ──────────────────
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── Database (Supabase Postgres — server-side ONLY) ───────────────────────
# Found in: Supabase → Project Settings → Database → URI (Direct connection)
DATABASE_URL=postgresql://postgres:[DB-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ── Auth ───────────────────────────────────────────────────────────────────
# Use a strong random string (at least 32 chars)
JWT_SECRET=change_me_to_a_strong_random_secret

# ── Supabase Client (frontend / VITE_ vars are safe to expose) ────────────
VITE_SUPABASE_URL=https://[PROJECT-REF].supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# ─────────────────────────────────────────────────────────────────────────────
# ⚡ Vercel Deployment — add these in:
#    Vercel Dashboard → Your Project → Settings → Environment Variables
#
#  Required:   DATABASE_URL, GROQ_API_KEY, JWT_SECRET, VITE_OPENWEATHER_API_KEY
#  Optional:   VITE_SUPABASE_URL, VITE_SUPABASE_PUBLISHABLE_KEY
# ─────────────────────────────────────────────────────────────────────────────
